   ],
   "source": [
    "# Process decennial AIAN census data (wide format to long format)\n",
    "print(\"\\nProcessing Decennial AIAN Census Data...\")\n",
    "\n",
    "# Load the AIAN census file\n",
    "aian_census = pd.read_csv(decennial_aian_path)\n",
    "print(f\"AIAN Census shape: {aian_census.shape}\")\n",
    "\n",
    "# Get the total population row (first data row after header)\n",
    "total_row = aian_census[aian_census['Label (Grouping)'] == 'Total:'].iloc[0]\n",
    "\n",
    "# Extract zip codes from column names (skip first column which is the label)\n",
    "zip_columns = aian_census.columns[1:]\n",
    "\n",
    "# Create a dataframe with zip codes and total population\n",
    "zip_pop_data = []\n",
    "for col in zip_columns:\n",
    "    # Extract zip code from column name like \"ZCTA5 06001!!Total population\"\n",
    "    if col.startswith('ZCTA5 '):\n",
    "        zip_code = col.replace('ZCTA5 ', '').split('!!')[0]\n",
    "        pop_value = total_row[col]\n",
    "        # Clean the population value (remove commas and quotes)\n",
    "        if pd.notna(pop_value):\n",
    "            pop_clean = str(pop_value).replace(',', '').replace('\"', '')\n",
    "            try:\n",
    "                pop_int = int(pop_clean)\n",
    "                zip_pop_data.append({'zip': zip_code, 'aian_total_pop': pop_int})\n",
    "            except:\n",
    "                pass\n",
    "\n",
    "# Create AIAN population dataframe\n",
    "aian_pop_df = pd.DataFrame(zip_pop_data)\n",
    "print(f\"AIAN population data shape: {aian_pop_df.shape}\")\n",
    "print(f\"Sample AIAN data:\\n{aian_pop_df.head()}\")\n",
    "\n",
    "# Convert zip to integer format for proper merging\n",
    "# First convert combined zip to integer (removing any decimals)\n",
    "combined['zip'] = combined['zip'].fillna(0).astype(int).astype(str).str.zfill(5)\n",
    "\n",
    "# Convert AIAN zip to same format (ensure 5-digit string)\n",
    "aian_pop_df['zip'] = aian_pop_df['zip'].astype(str).str.zfill(5)\n",
    "\n",
    "print(f\"Combined zip samples: {combined['zip'].head().tolist()}\")\n",
    "print(f\"AIAN zip samples: {aian_pop_df['zip'].head().tolist()}\")\n",
    "\n",
    "# Merge AIAN census data with combined dataset\n",
    "combined = combined.merge(aian_pop_df, on='zip', how='left')\n",
    "print(f\"Combined shape after AIAN merge: {combined.shape}\")\n",
    "print(f\"Rows with AIAN data: {combined['aian_total_pop'].notna().sum()}\")"
   ]
  },
