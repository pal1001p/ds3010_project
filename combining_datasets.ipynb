   "source": [
    "# Load and process demographics data\n",
    "print(\"\\nProcessing Demographics Data...\")\n",
    "\n",
    "# Load demographics file\n",
    "demographics = pd.read_csv(demographics_path)\n",
    "print(f\"Demographics shape: {demographics.shape}\")\n",
    "\n",
    "\n",
    "# Clean the data - remove the state total row and clean town names\n",
    "demographics = demographics[demographics['name'] != 'Connecticut'].copy()\n",
    "\n",
    "# Make town names lowercase\n",
    "demographics['name'] = demographics['name'].str.lower().str.strip()\n",
    "\n",
    "#remove the word town after the town names\n",
    "demographics['name'] = demographics['name'].str.replace(' town', '', regex=False)\n",
    "\n",
    "# Clean population values (remove quotes and commas)\n",
    "demographics['population'] = demographics['population'].str.replace('\"', '').str.replace(',', '').astype(int)\n",
    "\n",
    "print(f\"Demographics cleaned shape: {demographics.shape}\")\n",
    "print(f\"Sample demographics:\\n{demographics.head()}\")"
   ]
  },
