     "text": [
      "\n",
      "Making town/city names lowercase...\n",
      "Real Estate towns sample: ['ansonia' 'avon' 'bridgeport' 'burlington' 'bristol']\n",
      "School cities sample: ['new canaan' 'old greenwich' 'sherman' 'riverside' 'weston']\n",
      "CT zip cities sample: ['avon' 'bloomfield' 'bristol' 'burlington' 'broad brook']\n"
     ]
    }
   ],
   "source": [
    "# Make town/city names lowercase in all datasets\n",
    "print(\"\\nMaking town/city names lowercase...\")\n",
    "\n",
    "# Real Estate - lowercase the Town column\n",
    "real_estate['Town'] = real_estate['Town'].str.lower().str.strip()\n",
    "print(f\"Real Estate towns sample: {real_estate['Town'].unique()[:5]}\")\n",
    "\n",
    "# School Data - lowercase the City column\n",
    "school['City'] = school['City'].str.lower().str.strip()\n",
    "print(f\"School cities sample: {school['City'].unique()[:5]}\")\n",
    "\n",
    "# CT Zips - lowercase the city column\n",
    "ct_zips['city'] = ct_zips['city'].str.lower().str.strip()\n",
    "print(f\"CT zip cities sample: {ct_zips['city'].unique()[:5]}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 23,
   "id": "307e1793",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Real estate with zip codes: 243716 / 251976\n"
     ]
    }
   ],
   "source": [
    "# Create a mapping from town name to zip codes\n",
    "# Group by city name and collect all zip codes\n",
    "town_zip_mapping = ct_zips.groupby('city')['zip'].apply(list).to_dict()\n",
    "\n",
    "# Create reverse mapping (zip to town)\n",
    "zip_town_mapping = ct_zips.set_index('zip')['city'].to_dict()\n",
    "\n",
    "# Add a zip code column to real estate data based on town name\n",
    "# We'll try to match town to city in CT zips\n",
    "def get_primary_zip(town):\n",
    "    if town in town_zip_mapping:\n",
    "        zips = town_zip_mapping[town]\n",
    "        return zips[0] if zips else None\n",
    "    return None\n",
    "\n",
    "real_estate['zip'] = real_estate['Town'].apply(get_primary_zip)\n",
    "print(f\"Real estate with zip codes: {real_estate['zip'].notna().sum()} / {len(real_estate)}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 24,
   "id": "3237dbb1",
