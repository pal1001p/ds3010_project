   ],
   "source": [
    "# Load all datasets\n",
    "print(\"Loading datasets...\")\n",
    "\n",
    "# 1. Real Estate Data\n",
    "real_estate = pd.read_csv(real_estate_path)\n",
    "print(f\"Real Estate: {real_estate.shape}\")\n",
    "\n",
    "# 2. School Data\n",
    "school = pd.read_csv(school_path)\n",
    "print(f\"School: {school.shape}\")\n",
    "\n",
    "# 3. US Zip Codes (filter for Connecticut only)\n",
    "uszips = pd.read_csv(uszips_path)\n",
    "ct_zips = uszips[uszips['state_id'] == 'CT'].copy()\n",
    "print(f\"CT Zip Codes: {ct_zips.shape}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 22,
   "id": "e58792da",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
