     ]
    }
   ],
   "source": [
    "# Prepare School Data for merging\n",
    "# Rename City to Town for consistency\n",
    "school_clean = school.copy()\n",
    "school_clean = school_clean.rename(columns={'City': 'Town'})\n",
    "\n",
    "# Select relevant columns from school data\n",
    "school_cols = ['Town', 'Rank (of 177)', '# Elementary Schools', '# Middle Schools', \n",
    "               '# High Schools', '# Alt. Schools', '# Private Schools*', 'Rank score (2025)']\n",
    "school_available = [col for col in school_cols if col in school_clean.columns]\n",
    "school_clean = school_clean[school_available]\n",
    "\n",
    "print(\"School data columns:\", school_clean.columns.tolist())\n",
    "print(f\"School data shape: {school_clean.shape}\")"
   ]
  },
