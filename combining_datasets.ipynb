   "source": [
    "# Merge demographics data with combined dataset\n",
    "print(\"\\nMerging with Demographics Data...\")\n",
    "\n",
    "# Rename demographics town column to match\n",
    "demographics = demographics.rename(columns={'name': 'Town'})\n",
    "\n",
    "# Merge with combined data\n",
    "combined = combined.merge(demographics[['Town', 'population']], on='Town', how='left', suffixes=('', '_demo'))\n",
    "combined = combined.rename(columns={'population': 'town_population'})\n",
    "\n",
    "print(f\"Combined shape after demographics merge: {combined.shape}\")\n",
    "print(f\"Rows with demographics data: {combined['town_population'].notna().sum()}\")"
