    "combined = real_estate.merge(school_clean, on='Town', how='left')\n",
    "print(f\"Combined shape after school merge: {combined.shape}\")\n",
    "print(f\"Rows with school data: {combined['Rank (of 177)'].notna().sum()}\")"
   ]
