   "metadata": {},
   "outputs": [],
   "source": [
    "# Define file paths\n",
    "base_path = '/Users/val/Desktop/DS3000/project/'\n",
    "\n",
    "real_estate_path = base_path + 'ds3010_project-main/cleaned_real_estate_data.csv'\n",
    "school_path = base_path + 'CT_school_data.csv'\n",
    "uszips_path = base_path + 'simplemaps_uszips_basicv1/uszips.csv'\n",
    "decennial_aian_path = base_path + 'DECENNIALAIAN2010.HCT10-2026-04-30T215654.csv'\n",
    "demographics_path = base_path + 'Connecticut_DemographicsByCity.csv'"
   ]
